{
  "name": "sms-backend",
  "version": "1.0.0",
  "engines": {
  "node": "22.x"
 }
  "description": "Smart Management System — Waltern Tech Ltd",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child -r tsconfig-paths/register sms-backend/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node sms-backend/dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "africastalking": "^0.8.0",
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "morgan": "^1.10.0",
    "node-cron": "^4.4.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.3",
    "sequelize-typescript": "^2.1.6",
    "umzug": "^3.8.3",
