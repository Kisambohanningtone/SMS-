# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sms_agent_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_32_char_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_32_char_string
JWT_REFRESH_EXPIRES_IN=30d
OWNER_TOKEN_SECRET=change_this_to_yet_another_32_char_string
OWNER_TOKEN_EXPIRES_IN=30d

# ── KopoKopo ──────────────────────────────────────────────────────────────────
